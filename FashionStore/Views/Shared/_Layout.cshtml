@using Microsoft.AspNetCore.Http
@using FashionStore.Extensions
@using FashionStore.Models
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OWE</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-white text-neutral-900 font-sans antialiased flex flex-col min-h-screen">
    <header class="border-b border-neutral-200">
        <div class="max-w-7xl mx-auto px-6 lg:px-8">
            <div class="flex justify-between h-20 items-center">
                <div class="flex-shrink-0 flex items-center">
                    <a href="/" class="text-2xl font-black tracking-tighter uppercase">
                        OWE
                    </a>
                </div>
                <nav class="hidden md:flex space-x-12">
                    <a href="/" class="text-sm font-semibold tracking-wide uppercase hover:text-neutral-500 transition-colors">Trang Chủ</a>
                    <a href="/Products" class="text-sm font-semibold tracking-wide uppercase hover:text-neutral-500 transition-colors">Sản Phẩm</a>
                    <a href="/About" class="text-sm font-semibold tracking-wide uppercase hover:text-neutral-500 transition-colors">Giới Thiệu</a>
                </nav>
                <div class="flex items-center space-x-6">
                    <button id="search-toggle" class="text-sm font-semibold uppercase hover:text-neutral-500 transition-colors flex items-center gap-1">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        Tìm Kiếm
                    </button>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a href="/Account/Profile" class="text-sm font-semibold uppercase hover:text-neutral-500 transition-colors">
                            Hồ Sơ
                        </a>
                    }
                    else
                    {
                        <a href="/Account/Login" class="text-sm font-semibold uppercase hover:text-neutral-500 transition-colors">
                            Đăng Nhập
                        </a>
                    }
                    @{
                        var cart = HttpContextAccessor.HttpContext?.Session.Get<List<CartItem>>("Cart");
                        var cartCount = cart != null ? cart.Sum(c => c.Quantity) : 0;
                    }
                    <a href="/Cart" class="text-sm font-semibold uppercase hover:text-neutral-500 transition-colors flex items-center gap-2">
                        Giỏ Hàng <span class="bg-neutral-900 text-white text-xs px-2 py-0.5 rounded-full">@cartCount</span>
                    </a>
                </div>
            </div>
        </div>
    </header>

    <main role="main" class="flex-grow">
        @RenderBody()
    </main>

    <footer class="border-t border-neutral-200 bg-neutral-50 mt-24 py-16">
        <div class="max-w-7xl mx-auto px-6 lg:px-8 grid grid-cols-1 md:grid-cols-4 gap-12">
            <div class="col-span-1 md:col-span-2">
                <h2 class="text-3xl font-black tracking-tighter uppercase mb-6">OWE.</h2>
                <p class="text-neutral-500 max-w-sm">
                    Trang phục cơ bản mang phong cách tối giản. <br/> Thiết kế tinh tế, đề cao sự thoải mái.
                </p>
            </div>
            <div>
                <h3 class="text-xs font-bold tracking-widest uppercase text-neutral-400 mb-4">Thông Tin</h3>
                <ul class="space-y-3">
                    <li><a href="#" class="text-sm font-medium hover:text-neutral-500 transition-colors">Giao Hàng & Đổi Trả</a></li>
                    <li><a href="#" class="text-sm font-medium hover:text-neutral-500 transition-colors">Hướng Dẫn Chọn Size</a></li>
                    <li><a href="#" class="text-sm font-medium hover:text-neutral-500 transition-colors">Câu Hỏi Thường Gặp</a></li>
                </ul>
            </div>
            <div>
                <h3 class="text-xs font-bold tracking-widest uppercase text-neutral-400 mb-4">Liên Hệ</h3>
                <ul class="space-y-3">
                    <li class="text-sm font-medium text-neutral-500">Trường Đại học Công Thương TP.HCM</li>
                    <li class="text-sm font-medium text-neutral-500">140 Lê Trọng Tấn, Tây Thạnh, Tân Phú</li>
                    <li><a href="mailto:contact@huit.edu.vn" class="text-sm font-medium hover:text-neutral-900 transition-colors">contact@huit.edu.vn</a></li>
                </ul>
            </div>
        </div>
    </footer>

    <!-- Search Modal -->
    <div id="search-modal" class="fixed inset-0 z-50 hidden bg-black/40 backdrop-blur-sm flex justify-center items-start pt-16 md:pt-24 px-4 transition-opacity duration-300 opacity-0">
        <div class="bg-white w-full max-w-3xl shadow-2xl relative overflow-hidden transition-transform duration-300 -translate-y-4 scale-95 rounded-sm" id="search-modal-content">
            <button id="search-close" class="absolute top-6 right-6 text-neutral-400 hover:text-neutral-900 transition-colors z-10">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
            <div class="p-6 md:p-8 border-b border-neutral-100">
                <form action="/Search" method="get" class="flex items-center">
                    <svg class="w-6 h-6 text-neutral-400 mr-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    <input type="text" name="query" placeholder="Tìm kiếm..." class="w-full text-2xl font-medium outline-none bg-transparent placeholder-neutral-300" autofocus />
                </form>
            </div>
            <div class="p-6 md:p-8 bg-neutral-50">
                <h4 class="text-xs font-bold tracking-widest uppercase text-neutral-500 mb-6">Sản Phẩm Nổi Bật</h4>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    <a href="/Products/Details/1" class="group block">
                        <div class="aspect-square bg-neutral-200 overflow-hidden mb-3">
                            <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Pick" class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500 grayscale" />
                        </div>
                        <h5 class="text-sm font-bold uppercase truncate">Blazer Form Rộng</h5>
                        <p class="text-xs text-neutral-500 mt-1">1.250.000 ₫</p>
                    </a>
                    <a href="/Products/Details/2" class="group block">
                        <div class="aspect-square bg-neutral-200 overflow-hidden mb-3">
                            <img src="https://images.unsplash.com/photo-1591047139829-d91aecb6caea?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Pick" class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500 grayscale" />
                        </div>
                        <h5 class="text-sm font-bold uppercase truncate">Áo Khoác Canvas</h5>
                        <p class="text-xs text-neutral-500 mt-1">950.000 ₫</p>
                    </a>
                    <a href="/Products/Details/3" class="group block">
                        <div class="aspect-square bg-neutral-200 overflow-hidden mb-3">
                            <img src="https://images.unsplash.com/photo-1550614000-4b95d466f087?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Pick" class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500 grayscale" />
                        </div>
                        <h5 class="text-sm font-bold uppercase truncate">Quần Tây Xếp Ly</h5>
                        <p class="text-xs text-neutral-500 mt-1">680.000 ₫</p>
                    </a>
                    <a href="/Products/Details/4" class="group block">
                        <div class="aspect-square bg-neutral-200 overflow-hidden mb-3">
                            <img src="https://images.unsplash.com/photo-1576995853123-5a10305d93c0?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Pick" class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500 grayscale" />
                        </div>
                        <h5 class="text-sm font-bold uppercase truncate">Áo Sơ Mi Classic</h5>
                        <p class="text-xs text-neutral-500 mt-1">450.000 ₫</p>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function() {
            const modal = $('#search-modal');
            const content = $('#search-modal-content');
            const input = modal.find('input[name="query"]');

            $('#search-toggle').click(function(e) {
                e.preventDefault();
                modal.removeClass('hidden');
                modal[0].offsetHeight;
                modal.removeClass('opacity-0').addClass('opacity-100');
                content.removeClass('-translate-y-4 scale-95').addClass('translate-y-0 scale-100');
                setTimeout(() => input.focus(), 100);
            });

            $('#search-close').click(function() {
                modal.removeClass('opacity-100').addClass('opacity-0');
                content.removeClass('translate-y-0 scale-100').addClass('-translate-y-4 scale-95');
                setTimeout(() => {
                    modal.addClass('hidden');
                }, 300);
            });

            modal.click(function(e) {
                if ($(e.target).is(modal)) {
                    $('#search-close').click();
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
