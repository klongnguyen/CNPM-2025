<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin OWE</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-neutral-50 text-neutral-900 font-sans antialiased flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-neutral-900 text-white flex flex-col fixed inset-y-0 left-0">
        <div class="h-20 flex items-center px-8 border-b border-neutral-800">
            <a href="/Admin" class="text-2xl font-black tracking-tighter uppercase">OWE.</a>
        </div>
        <nav class="flex-grow py-8 px-4 space-y-2">
            <a href="/Admin" class="block px-4 py-3 rounded text-sm font-semibold tracking-wide uppercase hover:bg-neutral-800 transition-colors">Tổng Quan</a>
            <a href="/Admin/Products" class="block px-4 py-3 rounded text-sm font-semibold tracking-wide uppercase hover:bg-neutral-800 transition-colors">Sản Phẩm</a>
            <a href="/Admin/Orders" class="block px-4 py-3 rounded text-sm font-semibold tracking-wide uppercase hover:bg-neutral-800 transition-colors">Đơn Hàng</a>
        </nav>
        <div class="p-4 border-t border-neutral-800">
            <a href="/" class="block px-4 py-2 text-xs font-bold text-neutral-400 hover:text-white uppercase tracking-widest">Trở về cửa hàng</a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="ml-64 flex-grow flex flex-col min-h-screen">
        <header class="h-20 bg-white border-b border-neutral-200 flex items-center justify-between px-8 sticky top-0 z-10">
            <h1 class="text-xl font-black uppercase tracking-wide">@ViewData["Title"]</h1>
            <div class="flex items-center gap-4">
                <span class="text-sm font-semibold">Admin User</span>
            </div>
        </header>
        <div class="p-8 flex-grow">
            @RenderBody()
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
