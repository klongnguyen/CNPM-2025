@{
    ViewData["Title"] = "Đặt Hàng Thành Công";
}
<section class="max-w-md mx-auto px-6 py-24 text-center">
    <div class="w-24 h-24 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-8">
        <svg class="w-12 h-12 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path>
        </svg>
    </div>
    <h1 class="text-3xl font-black tracking-tighter uppercase mb-4">Đặt Hàng Thành Công!</h1>
    <p class="text-neutral-500 mb-8">Cảm ơn bạn đã mua sắm. Đơn hàng của bạn đang được xử lý.</p>
    <a href="/Products" class="inline-block bg-neutral-900 text-white text-sm font-bold tracking-widest uppercase px-8 py-4 hover:bg-neutral-800 transition-all">
        Tiếp Tục Mua Sắm
