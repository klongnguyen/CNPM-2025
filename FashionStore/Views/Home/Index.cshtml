@model IEnumerable<FashionStore.Models.Entities.Product>
@{ 
    ViewData["Title"] = "Trang Chủ";
}

<!-- Hero Section -->
<section class="max-w-7xl mx-auto px-6 lg:px-8 py-20 lg:py-32 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
    <div class="lg:col-span-7">
        <h1 class="text-6xl md:text-8xl font-black tracking-tighter uppercase leading-[0.85]">
            Định Hình <br/> Phong Cách <br/> <span class="text-neutral-300">Của Bạn.</span>
        </h1>
    </div>
    <div class="lg:col-span-5">
        <p class="text-lg text-neutral-600 font-medium leading-relaxed max-w-md">
            Bộ sưu tập thời trang tối giản. Chúng tôi tập trung vào form dáng, tính ứng dụng và loại bỏ hoàn toàn các chi tiết thừa thãi.
        </p>
        <div class="mt-10">
            <a href="/Products" class="inline-block bg-neutral-900 text-white text-sm font-bold tracking-widest uppercase px-8 py-4 hover:bg-neutral-800 transition-all">
                Khám Phá Ngay
            </a>
        </div>
    </div>
</section>

<!-- Featured Image Section (Asymmetric) -->
<section class="w-full">
    <div class="h-[60vh] md:h-[80vh] w-full bg-neutral-100 overflow-hidden relative">
        <img src="https://images.unsplash.com/photo-1445205170230-053b83016050?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80" alt="Fashion Model" class="absolute inset-0 w-full h-full object-cover object-center grayscale opacity-90" />
        <div class="absolute bottom-8 left-8 bg-white p-6">
            <span class="text-xs font-bold tracking-widest uppercase text-neutral-400">Thu Đông 25/26</span>
            <h2 class="text-2xl font-black uppercase mt-2">Áo Dạ <br/> Nguyên Khối</h2>
        </div>
    </div>
</section>

<!-- New Arrivals Grid -->
<section class="max-w-7xl mx-auto px-6 lg:px-8 py-24">
    <div class="flex justify-between items-end mb-16">
        <h2 class="text-4xl font-black tracking-tighter uppercase">
            Sản Phẩm <br/> Mới Nhất
        </h2>
        <a href="/Products" class="text-sm font-bold uppercase tracking-widest hover:text-neutral-500 transition-colors border-b-2 border-neutral-900 pb-1">
            Xem Tất Cả
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-8 gap-y-16">
        @if(Model != null)
        {
            foreach(var item in Model)
            {
                <a href="/Products/Details/@item.Id" class="group cursor-pointer block">
                    <div class="aspect-[3/4] bg-neutral-100 overflow-hidden mb-6">
                        <img src="@item.ImageUrl" alt="@item.Name" class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700 ease-in-out grayscale" />
                    </div>
                    <div class="flex justify-between items-start">
                        <div>
                            <h3 class="text-lg font-bold uppercase tracking-wide">@item.Name</h3>
                            <p class="text-sm text-neutral-500 mt-1">@item.Category</p>
                        </div>
                        <span class="text-lg font-bold">$@item.CatalogPrice.ToString("0.00")</span>
                    </div>
                </a>
            }
        }
    </div>
</section>
